{
  "name": "forscore-viewer",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "build": "vite build && tsup src/server/index.ts --format cjs --out-dir dist/server",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:e2e": "DATA_DIR=/tmp/forscoreviewer playwright test",
    "typecheck": "tsc --noEmit"
  },
  "description": "",
  "main": "postcss.config.js",
  "directories": {
    "test": "tests"
  },
  "keywords": [],
